{
  "$schema": "https://raw.githubusercontent.com/nicmr/tauri/tauri-v2/packages/tauri/schema.json",
  "productName": "bench-app",
  "version": "0.1.0",
  "identifier": "com.tauri-conduit.bench-app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Conduit E2E Benchmark",
        "width": 900,
        "height": 700
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "conduit": {}
  }
}
